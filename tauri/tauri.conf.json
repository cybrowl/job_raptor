{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JobFlow",
  "version": "0.1.0",
  "identifier": "app.jobflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JobFlow",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:jobflow.db"]
    }
  },
  "bundle": {
    "active": false
  }
}
